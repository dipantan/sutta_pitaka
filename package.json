{
  "name": "sutta_pitaka",
  "main": "expo-router/entry",
  "version": "1.0.2",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "prebuild:ios": "expo prebuild --clean --platform ios",
    "prebuild:android": "expo prebuild --clean --platform android",
    "build:android": "eas build -p android --profile preview",
    "build:local-apk": "cd android && ./gradlew assembleRelease && cd .. && mv android/app/build/outputs/apk/release/app-*-release.apk ./",
    "create:github-release": "node -e \"const fs = require('fs'); const notes = fs.existsSync('changelog.md') ? fs.readFileSync('changelog.md', 'utf8').trim() : ''; if (!notes) { console.error('Error: changelog.md is missing or empty'); process.exit(1); } process.exit(0);\" && [ -z \"$TAG\" ] && { echo 'Error: Tag name is required. Use --tag=<tag-name>'; exit 1; } || gh release create \"$TAG\" --notes-file changelog.md ./app-*-release.apk",
    "build-and-release": "npm run build:local-apk && npm run create:github-release --tag=\"$TAG\""
  },
  "dependencies": {
    "@expo/vector-icons": "^14.1.0",
    "@tanstack/query-async-storage-persister": "^5.83.0",
    "@tanstack/react-query": "^5.83.0",
    "@tanstack/react-query-persist-client": "^5.83.0",
    "axios": "^1.9.0",
    "expo": "53.0.17",
    "expo-constants": "~17.1.7",
    "expo-dev-client": "~5.2.4",
    "expo-font": "~13.3.2",
    "expo-image": "~2.4.0",
    "expo-linking": "~7.1.7",
    "expo-router": "~5.1.3",
    "expo-status-bar": "~2.2.3",
    "expo-system-ui": "~5.0.10",
    "expo-updates": "~0.28.16",
    "expo-web-browser": "~14.2.0",
    "html-react-parser": "^5.2.5",
    "moti": "^0.30.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.5",
    "react-native-blob-util": "^0.22.2",
    "react-native-bootsplash": "^6.3.10",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-mmkv": "^3.3.0",
    "react-native-paper": "^5.14.5",
    "react-native-reanimated": "~3.17.4",
    "react-native-responsive-fontsize": "^0.5.1",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-simple-dialogs": "^2.1.1",
    "react-native-view-shot": "4.0.3",
    "react-native-web": "~0.20.0",
    "react-native-webview": "13.13.5",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@react-native-community/cli": "latest",
    "@types/react": "~19.0.10",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~9.2.0",
    "typescript": "~5.8.3"
  },
  "private": true
}
